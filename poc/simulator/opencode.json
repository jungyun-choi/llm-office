{
  "$schema": "https://opencode.ai/config.json",
  "model": "{env:AI_OFFICE_OPENCODE_MODEL}",
  "small_model": "{env:AI_OFFICE_OPENCODE_MODEL}",
  "share": "disabled",
  "autoupdate": false,
  "snapshot": false,
  "plugin": [],
  "mcp": {},
  "instructions": [],
  "permission": {
    "*": "deny"
  },
  "agent": {
    "orchestrator": {
      "description": "Coordinates a read-only feature brief for Synthetic FlashSim",
      "mode": "primary",
      "prompt": "{file:./prompts/orchestrator.md}",
      "model": "{env:AI_OFFICE_OPENCODE_MODEL}",
      "permission": { "*": "deny", "task": "deny" }
    },
    "research": {
      "description": "Finds evidence in the supplied synthetic snapshot",
      "mode": "subagent",
      "prompt": "{file:./prompts/research.md}",
      "model": "{env:AI_OFFICE_OPENCODE_MODEL}",
      "permission": { "*": "deny", "task": "deny" }
    },
    "framework": {
      "description": "Maps a request onto the synthetic simulator architecture",
      "mode": "subagent",
      "prompt": "{file:./prompts/framework.md}",
      "model": "{env:AI_OFFICE_OPENCODE_MODEL}",
      "permission": { "*": "deny", "task": "deny" }
    },
    "estimate": {
      "description": "Produces a relative estimate for the synthetic change",
      "mode": "subagent",
      "prompt": "{file:./prompts/estimate.md}",
      "model": "{env:AI_OFFICE_OPENCODE_MODEL}",
      "permission": { "*": "deny", "task": "deny" }
    },
    "test": {
      "description": "Designs tests without executing them",
      "mode": "subagent",
      "prompt": "{file:./prompts/test.md}",
      "model": "{env:AI_OFFICE_OPENCODE_MODEL}",
      "permission": { "*": "deny", "task": "deny" }
    },
    "git": {
      "description": "Creates a synthetic issue draft and never publishes it",
      "mode": "subagent",
      "prompt": "{file:./prompts/git.md}",
      "model": "{env:AI_OFFICE_OPENCODE_MODEL}",
      "permission": { "*": "deny", "task": "deny" }
    }
  }
}
