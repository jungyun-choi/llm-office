{
  "name": "ai-office",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "dev:poc": "AI_OFFICE_LOCAL_PROXY_ENABLED=1 WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "dev:office": "tsx scripts/dev-office.ts",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "poc:bridge": "npm run poc:bridge:zen",
    "poc:bridge:zen": "AI_OFFICE_LOCAL_RUNNER_ENABLED=1 AI_OFFICE_AGENT_RUNTIME=opencode AI_OFFICE_OPENCODE_PROFILE=zen AI_OFFICE_ZEN_SHARED_STATE_ACK=synthetic-only tsx scripts/poc-bridge.ts",
    "poc:bridge:codex": "AI_OFFICE_LOCAL_RUNNER_ENABLED=1 AI_OFFICE_AGENT_RUNTIME=codex tsx scripts/poc-bridge.ts",
    "poc:bridge:opencode-internal": "AI_OFFICE_LOCAL_RUNNER_ENABLED=1 AI_OFFICE_AGENT_RUNTIME=opencode AI_OFFICE_OPENCODE_PROFILE=internal tsx scripts/poc-bridge.ts",
    "poc:bridge:company": "AI_OFFICE_LOCAL_RUNNER_ENABLED=1 AI_OFFICE_AGENT_RUNTIME=opencode AI_OFFICE_OPENCODE_PROFILE=company tsx scripts/poc-bridge.ts",
    "poc:bridge:office": "npm run poc:bridge:office:poc",
    "poc:bridge:office:poc": "AI_OFFICE_LOCAL_RUNNER_ENABLED=1 AI_OFFICE_AGENT_RUNTIME=opencode AI_OFFICE_OPENCODE_PROFILE=zen AI_OFFICE_ZEN_SHARED_STATE_ACK=synthetic-only AI_OFFICE_CODING_ENABLED=1 AI_OFFICE_CLAUDE_PROFILE=synthetic tsx scripts/poc-bridge.ts",
    "poc:bridge:internal": "AI_OFFICE_LOCAL_RUNNER_ENABLED=1 AI_OFFICE_AGENT_RUNTIME=opencode tsx scripts/poc-bridge.ts",
    "poc:simulator:test": "python3 -m unittest discover -s poc/simulator/tests -p 'test_*.py'",
    "test": "npm run build && node --test tests/rendered-html.test.mjs && node --import tsx --test tests/poc-runtime.test.ts tests/job-http.test.ts tests/office-jobs-security.test.ts tests/sequential-agent-runtime.test.ts tests/company-extension-boundary.test.ts tests/company-opencode-runtime.test.ts app/features/office/api/poc-client.test.ts app/features/office/api/job-contract.test.ts app/features/office/api/map-poc-result.test.ts app/features/office/components/office-status.test.tsx app/features/office/hooks/use-office-workflow.test.ts app/features/office/orbit-intake.test.ts",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.25.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.82.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@openai/codex": "0.144.6",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
