{
  "note": "AI Office м„ңлІ„ нҷҳкІҪліҖмҲҳ л§Өн•‘ мҳҲмӢңмһ…лӢҲлӢӨ. OpenCodeмқҳ OPENCODE_CONFIG лҳҗлҠ” custom agent configлЎң м „лӢ¬н•ҳм§Җ л§Ҳм„ёмҡ”.",
  "profile": "company",
  "providerAllowlist": ["codemate"],
  "models": {
    "orchestrator": "{env:AI_OFFICE_MODEL_ORCHESTRATOR}",
    "research": "{env:AI_OFFICE_MODEL_RESEARCH}",
    "framework": "{env:AI_OFFICE_MODEL_FRAMEWORK}",
    "estimate": "{env:AI_OFFICE_MODEL_ESTIMATE}",
    "test": "{env:AI_OFFICE_MODEL_TEST}",
    "git": "{env:AI_OFFICE_MODEL_GIT}"
  },
  "runtimePolicy": {
    "sequentialOrder": [
      "research",
      "framework",
      "estimate",
      "test",
      "git",
      "orchestrator"
    ],
    "turnTimeoutMs": 3600000,
    "automaticRetries": 0,
    "tools": false,
    "permissions": "deny",
    "mcp": false,
    "customAgents": false,
    "pureFlag": false,
    "defaultPluginsRequiredForCodemateAuth": true
  }
}
